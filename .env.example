# Database Configuration
DATABASE_URL="mongodb://username:password@localhost:27017/bot_baileys?authSource=admin"

# Bot Configuration (optional)
BOT_NAME="Bot-Baileys-AI"

# Session filters (comma-separated session ids)
# Leave empty to load every saved session.
# EXCLUDE_SESSIONS: skip these when auto-loading from DB (e.g. exclude 'dev' in production Docker)
# INCLUDE_SESSIONS: only load these (overrides EXCLUDE_SESSIONS)
# EXCLUDE_SESSIONS="dev"
# INCLUDE_SESSIONS=""

# Owner Configuration (comma-separated WhatsApp numbers with @s.whatsapp.net)
OWNER_NUMBERS="628123456789@s.whatsapp.net"

# Prefix Configuration (comma-separated prefixes)
PREFIXES="!,.,#,/"

# Logger Configuration
LOG_LEVEL="silent"  # Options: trace, debug, info, warn, error, fatal, silent
NODE_ENV="production"  # Options: development, production

# AI Provider Configuration
# Options: "openrouter" | "ollama"
AI_PROVIDER="openrouter"

# OpenRouter AI Configuration (used when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="anthropic/claude-3-haiku"

# Ollama Configuration (used when AI_PROVIDER=ollama)
# Example: http://localhost:11434 or http://your-ollama-host:11434
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="glm-5.1:cloud"
