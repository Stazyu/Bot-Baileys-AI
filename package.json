{
  "name": "Bot-Baileys-AI",
  "version": "1.0.0",
  "description": "Multi-session WhatsApp bot using Baileys with PostgreSQL and Prisma",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --include 'src/**/*.ts' src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "baileys",
    "multi-session",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@innovatorssoft/baileys": "^7.4.3",
    "@prisma/client": "^5.22.0",
    "@tobyg74/tiktok-api-dl": "^1.3.7",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.1",
    "link-preview-js": "^3.0.0",
    "moment": "^2.30.1",
    "nexo-aio-downloader": "github:Stazyu/nexo-aio-downloader",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "wa-sticker-formatter": "^4.4.4",
    "youtube-dl-exec": "^3.1.6"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "baileys": "7.0.0-rc11",
    "prisma": "^5.20.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
